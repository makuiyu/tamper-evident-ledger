# Postgres connection (used by app + alembic + scripts)
# Default matches docker-compose.yml service `db` exposed on host port 55432
# to avoid clashing with any local Postgres already on 5432.
DATABASE_URL=postgresql+asyncpg://audit:audit@localhost:55432/audit

# Used by Alembic (sync driver) — same DB, different dialect string
ALEMBIC_DATABASE_URL=postgresql+psycopg://audit:audit@localhost:55432/audit

# AES-256-GCM field encryption key.
# Any string — SHA-256 derives a 32-byte key. Rotate via re-encrypt-and-rewrite.
# DO NOT commit a real key. Generate one with: python -c "import secrets;print(secrets.token_urlsafe(32))"
FIELD_ENCRYPTION_KEY=change-me-in-production-use-a-32-byte-random-secret

# Default organization used by demo scripts (seed / tamper / verify)
DEMO_ORG_ID=00000000-0000-0000-0000-000000000001
